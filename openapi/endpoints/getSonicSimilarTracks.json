{
    "get": {
        "summary": "Returns similar tracks based on sonic (audio) analysis.",
        "description": "Returns tracks that are sonically similar to a given track, based on audio analysis. Each result includes its normalized distance from the query track.",
        "operationId": "getSonicSimilarTracks",
        "tags": [
            "Browsing",
            "Addition"
        ],
        "parameters": [
            {
                "name": "id",
                "in": "query",
                "description": "The ID of the song.",
                "required": true,
                "schema": {
                    "type": "string"
                }
            },
            {
                "name": "count",
                "in": "query",
                "description": "Max number of similar tracks to return.",
                "required": false,
                "schema": {
                    "type": "integer",
                    "default": 10,
                    "minimum": 0
                }
            }
        ],
        "responses": {
            "200": {
                "description": "Successful or failed response",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "./getSonicSimilarTracks/GetSonicSimilarTracksResponse.json"
                        }
                    }
                }
            }
        },
        "externalDocs": {
            "description": "getSonicSimilarTracks",
            "url": "https://opensubsonic.netlify.app/docs/endpoints/getsonicsimilartracks/"
        }
    },

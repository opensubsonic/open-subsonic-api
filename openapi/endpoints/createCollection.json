                "schema": {
                    "type": "string"
                }
            },
            {
                "name": "songId",
                "in": "query",
                "description": "ID of a song in the collection. Use one `songId` parameter for each song in the collection.",
                "explode": true,
                "style": "form",
                "schema": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            {
                "name": "albumId",
                "in": "query",
                "description": "ID of an album in the collection. Use one `albumId` parameter for each album in the collection.",
                "explode": true,
                "style": "form",
                "schema": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            {
                "name": "artistId",
                "in": "query",
                "description": "ID of an artist in the collection. Use one `artistId` parameter for each artist in the collection.",
                "explode": true,
                "style": "form",
                "schema": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            {
                "name": "playlistId",
                "in": "query",
                "description": "ID of an playlist in the collection. Use one `playlistId` parameter for each playlist in the collection.",
                "explode": true,
                "style": "form",
                "schema": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        ],
        "responses": {
            "200": {
                "description": "Successful or failed response",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "./createCollection/CreateCollectionResponse.json"
                        }
                    }
                }

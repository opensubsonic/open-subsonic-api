{
    "get": {
        "summary": "Returns similar tracks based on audio analysis.",
        "description": "Returns a list of tracks that are similar to the given track, using audio embedding similarity. Supports filtering by album, deduplication, and radius-based similarity.",
        "operationId": "similarTracks",
        "tags": [
            "Browsing",
            "Addition"
        ],
        "parameters": [
            {
                "name": "itemId",
                "in": "query",
                "description": "The ID of the track to find similar tracks for.",
                "required": true,
                "schema": {
                    "type": "string"
                }
            },
            {
                "name": "n",
                "in": "query",
                "description": "The maximum number of similar tracks to return.",
                "required": false,
                "schema": {
                    "type": "integer",
                    "default": 10,
                    "minimum": 1
                }
            },
            {
                "name": "eliminateDuplicates",
                "in": "query",
                "description": "Whether to eliminate duplicate tracks from the results.",
                "required": false,
                "schema": {
                    "type": "boolean",
                    "default": true
                }
            },
            {
                "name": "radiusSimilarity",
                "in": "query",
                "description": "Whether to use radius-based similarity search.",
                "required": false,
                "schema": {
                    "type": "boolean",
                    "default": true
                }
            },
            {
                "name": "album",
                "in": "query",
                "description": "Filter results by album name.",
                "required": false,
                "schema": {
                    "type": "string"
                }
            }
        ],
        "responses": {
            "200": {
                "description": "Successful or failed response",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "./similarTracks/SimilarTracksResponse.json"
                        }
                    }
                }
            }
        },
        "externalDocs": {
            "description": "similarTracks",
            "url": "https://opensubsonic.netlify.app/docs/endpoints/similartracks/"
        }
    },
    "post": {
        "summary": "Returns similar tracks based on audio analysis.",
        "description": "Returns a list of tracks that are similar to the given track, using audio embedding similarity. Supports filtering by album, deduplication, and radius-based similarity.\n\nRequires OpenSubsonic extension name `formPost` (As returned by `getOpenSubsonicExtensions`)",
        "operationId": "postSimilarTracks",
        "tags": [
            "Browsing"
        ],
        "requestBody": {
            "required": true,
            "content": {
                "application/x-www-form-urlencoded": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "itemId": {
                                "type": "string",
                                "description": "The ID of the track to find similar tracks for."
                            },
                            "n": {
                                "type": "integer",
                                "default": 10,
                                "minimum": 1,
                                "description": "The maximum number of similar tracks to return."
                            },
                            "eliminateDuplicates": {
                                "type": "boolean",
                                "default": true,
                                "description": "Whether to eliminate duplicate tracks from the results."
                            },
                            "radiusSimilarity": {
                                "type": "boolean",
                                "default": true,
                                "description": "Whether to use radius-based similarity search."
                            },
                            "album": {
                                "type": "string",
                                "description": "Filter results by album name."
                            }
                        },
                        "required": [
                            "itemId"
                        ]
                    }
                }
            }
        },
        "parameters": [],
        "responses": {
            "200": {
                "description": "Successful or failed response",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "./similarTracks/SimilarTracksResponse.json"
                        }
                    }
                }
            },
            "405": {
                "$ref": "../responses/HTTPFormPostNotSupported.json"
            }
        },
        "externalDocs": {
            "description": "similarTracks",
            "url": "https://opensubsonic.netlify.app/docs/endpoints/similartracks/"
        }
    }
}

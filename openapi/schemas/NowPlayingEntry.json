{
    "allOf": [
        {
            "$ref": "./Child.json"
        },
        {
            "type": "object",
            "description": "NowPlayingEntry.",
            "externalDocs": {
                "description": "NowPlayingEntry",
                "url": "https://opensubsonic.netlify.app/docs/responses/nowplayingentry/"
            },
            "properties": {
                "username": {
                    "type": "string",
                    "description": "The username"
                },
                "minutesAgo": {
                    "type": "integer",
                    "description": "Last update"
                },
                "playerId": {
                    "type": "integer",
                    "description": "Player Id"
                },
                "playerName": {
                    "type": "string",
                    "description": "Player name"
                },
                "state": {
                    "type": "string",
                    "description": "Playback state.",
                    "enum": [
                        "playing",
                        "paused",
                        "stopped"
                    ]
                },
                "positionMs": {
                    "type": "integer",
                    "description": "Current playback position in milliseconds (Calculated by the server from the last playbackReport call received)"
                },
                "playbackRate": {
                    "type": "number",
                    "format": "float",
                    "description": "Playback speed multiplier"
                }
            },
            "required": [
                "username",
                "minutesAgo",
                "playerId"
            ]
        }
    ]
}
{
    "type": "object",
    "description": "An extendedLibrary version 1 album query. An empty object requests the first page, in id order, with core fields only.",
    "additionalProperties": false,
    "properties": {
        "properties": {
            "type": "array",
            "uniqueItems": true,
            "description": "Optional AlbumID3 fields to return in addition to id, name, songCount, duration, and created. AlbumID3.song is intentionally unavailable. Omitted or empty means core fields only.",
            "items": {
                "type": "string",
                "enum": [
                    "version", "artist", "artistId", "coverArt", "playCount",
                    "starred", "year", "genre", "played", "userRating",
                    "recordLabels", "musicBrainzId", "genres", "artists",
                    "displayArtist", "releaseTypes", "moods", "sortName",
                    "originalReleaseDate", "releaseDate", "isCompilation",
                    "explicitStatus", "discTitles"
                ]
            }
        },
        "filter": {
            "$ref": "./ExtendedLibraryAlbumFilter.json"
        },
        "sort": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "uniqueItems": true,
            "description": "Ordered unique sort fields. If id is explicit it must be last; otherwise id ascending is appended.",
            "items": {
                "$ref": "./ExtendedLibraryAlbumSort.json"
            }
        },
        "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 500,
            "default": 100
        },
        "cursor": {
            "type": "string",
            "description": "An opaque forward-only continuation token returned by the same endpoint."
        }
    }
}
